<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Meryem Güçlü — Software Developer & Data Enthusiast. Python, C#, JavaScript, Veri Analizi ve Web Geliştirme projelerim ile tanışın." />
  <meta name="keywords" content="Meryem Güçlü, Software Developer, Data Science, Python, Portfolio, Yazılım Geliştirici" />
  <meta name="author" content="Meryem Güçlü" />
  <meta property="og:title" content="Meryem Güçlü | Portfolio" />
  <meta property="og:description" content="Software Developer & Data Enthusiast — Projeler, Yetenekler ve daha fazlası." />
  <meta property="og:type" content="website" />
  <title>@ViewData["Title"] - Meryem Güçlü</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>

  <!-- Navigation -->
  <nav id="navbar" class="navbar">
    <div class="nav-container">
      <a href="#hero" class="nav-logo" id="nav-logo">MG</a>
      <ul class="nav-links" id="nav-links">
        <li><a href="#about" id="nav-about">Hakkımda</a></li>
        <li><a href="#skills" id="nav-skills">Yetenekler</a></li>
        <li><a href="#projects" id="nav-projects">Projeler</a></li>
        <li><a href="#experience" id="nav-experience">Deneyim</a></li>
        <li><a href="#education" id="nav-education">Eğitim</a></li>
        <li><a href="#contact" id="nav-contact">İletişim</a></li>
      </ul>
      <button class="hamburger" id="hamburger" aria-label="Menüyü aç">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  @RenderBody()

  <!-- Footer -->
  <footer class="footer" id="footer">
    <div class="footer-container">
      <div class="footer-logo" id="footer-logo">MG</div>
      <p class="footer-text" id="footer-text">
        © 2026 Meryem Güçlü. Tüm hakları saklıdır.
      </p>
      <div class="footer-links" id="footer-links">
        <a href="https://github.com/meryemgcl" target="_blank" id="footer-github">GitHub</a>
        <a href="https://www.linkedin.com/in/meryemgüçlü" target="_blank" id="footer-linkedin">LinkedIn</a>
        <a href="https://medium.com/@@meriguclu" target="_blank" id="footer-medium">Medium</a>
      </div>
    </div>
  </footer>

  <script src="~/js/script.js" asp-append-version="true"></script>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
